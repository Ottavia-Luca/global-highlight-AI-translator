# API
DEEPSEEK_API_KEY=sk-your-api-key-here
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_API_MODEL=deepseek-v4-flash
DEEPSEEK_API_TIMEOUT=10
DEEPSEEK_API_MAX_TOKENS=512

# System prompt
DEEPSEEK_SYSTEM_PROMPT=你是翻译助手。英文翻译成中文，中文翻译成英文。专有名词缩写按"全称是 XXX（YYY）"输出,如全称是Convolutional Neural Network（卷积神经网络）。简洁输出。


# Cache
DEEPSEEK_CACHE_MAX_ENTRIES=10000
DEEPSEEK_CACHE_TTL_DAYS=30

# UI
DEEPSEEK_UI_ICON_SIZE=24
DEEPSEEK_UI_FLOAT_WINDOW_WIDTH=250
DEEPSEEK_UI_FLOAT_WINDOW_MAX_HEIGHT=320
DEEPSEEK_UI_HOVER_DELAY=200

